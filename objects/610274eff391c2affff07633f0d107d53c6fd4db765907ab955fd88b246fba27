[{"leetcode_no":2343,"name":"Query Kth Smallest Trimmed Number","solutions":{"approach_1":{"cpp":"class Solution {\n    bool isTrimmedLess(const vector<string>& nums,int first,int second,int trimLength) {\n        int digitCount=nums[0].size();\n        int start=digitCount-trimLength;\n\n        for(int pos=start;pos<digitCount;pos++) {\n            if(nums[first][pos]!=nums[second][pos])\n                return nums[first][pos]<nums[second][pos];\n        }\n\n        return first<second;\n    }\n\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums,vector<vector<int>>& queries) {\n        int size=nums.size();\n        vector<int> answer;\n\n        for(auto& query:queries) {\n            int kth=query[0];\n            int trimLength=query[1];\n            vector<int> order(size);\n\n            iota(order.begin(),order.end(),0);\n\n            sort(order.begin(),order.end(),[&](int first,int second) {\n                return isTrimmedLess(nums,first,second,trimLength);\n            });\n\n            answer.push_back(order[kth-1]);\n        }\n\n        return answer;\n    }\n};"},"approach_2":{"cpp":"class Solution {\n    bool isTrimmedLess(const vector<string>& nums,int first,int second,int trimLength) {\n        int digitCount=nums[0].size();\n\n        for(int pos=digitCount-trimLength;pos<digitCount;pos++) {\n            if(nums[first][pos]!=nums[second][pos])\n                return nums[first][pos]<nums[second][pos];\n        }\n\n        return first<second;\n    }\n\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums,vector<vector<int>>& queries) {\n        int size=nums.size();\n        int digitCount=nums[0].size();\n        vector<vector<int>> orderByTrim(digitCount+1);\n        vector<bool> trimUsed(digitCount+1,false);\n\n        for(auto& query:queries)\n            trimUsed[query[1]]=true;\n\n        for(int trimLength=1;trimLength<=digitCount;trimLength++) {\n            if(!trimUsed[trimLength])\n                continue;\n\n            orderByTrim[trimLength].resize(size);\n            iota(orderByTrim[trimLength].begin(),orderByTrim[trimLength].end(),0);\n\n            sort(orderByTrim[trimLength].begin(),orderByTrim[trimLength].end(),[&](int first,int second) {\n                return isTrimmedLess(nums,first,second,trimLength);\n            });\n        }\n\n        vector<int> answer;\n\n        for(auto& query:queries)\n            answer.push_back(orderByTrim[query[1]][query[0]-1]);\n\n        return answer;\n    }\n};"},"approach_3":{"cpp":"class Solution {\n    bool isTrimmedLess(const vector<string>& nums,int first,int second,int trimLength) {\n        int digitCount=nums[0].size();\n\n        for(int pos=digitCount-trimLength;pos<digitCount;pos++) {\n            if(nums[first][pos]!=nums[second][pos])\n                return nums[first][pos]<nums[second][pos];\n        }\n\n        return first<second;\n    }\n\n    void mergeRange(vector<int>& order,vector<int>& buffer,int left,int mid,int right,const vector<string>& nums,int trimLength) {\n        int leftIndex=left;\n        int rightIndex=mid+1;\n        int writeIndex=left;\n\n        while(leftIndex<=mid&&rightIndex<=right) {\n            if(isTrimmedLess(nums,order[leftIndex],order[rightIndex],trimLength))\n                buffer[writeIndex++]=order[leftIndex++];\n            else\n                buffer[writeIndex++]=order[rightIndex++];\n        }\n\n        while(leftIndex<=mid)\n            buffer[writeIndex++]=order[leftIndex++];\n\n        while(rightIndex<=right)\n            buffer[writeIndex++]=order[rightIndex++];\n\n        for(int index=left;index<=right;index++)\n            order[index]=buffer[index];\n    }\n\n    void mergeSort(vector<int>& order,vector<int>& buffer,int left,int right,const vector<string>& nums,int trimLength) {\n        if(left>=right)\n            return;\n\n        int mid=left+(right-left)/2;\n\n        mergeSort(order,buffer,left,mid,nums,trimLength);\n        mergeSort(order,buffer,mid+1,right,nums,trimLength);\n        mergeRange(order,buffer,left,mid,right,nums,trimLength);\n    }\n\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums,vector<vector<int>>& queries) {\n        int size=nums.size();\n        vector<int> answer;\n\n        for(auto& query:queries) {\n            int kth=query[0];\n            int trimLength=query[1];\n            vector<int> order(size);\n            vector<int> buffer(size);\n\n            iota(order.begin(),order.end(),0);\n            mergeSort(order,buffer,0,size-1,nums,trimLength);\n            answer.push_back(order[kth-1]);\n        }\n\n        return answer;\n    }\n};"},"approach_4":{"cpp":"class Solution {\n    bool isTrimmedLess(const vector<string>& nums,int first,int second,int trimLength) {\n        int digitCount=nums[0].size();\n\n        for(int pos=digitCount-trimLength;pos<digitCount;pos++) {\n            if(nums[first][pos]!=nums[second][pos])\n                return nums[first][pos]<nums[second][pos];\n        }\n\n        return first<second;\n    }\n\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums,vector<vector<int>>& queries) {\n        int size=nums.size();\n        vector<int> answer;\n\n        for(auto& query:queries) {\n            int kth=query[0];\n            int trimLength=query[1];\n\n            auto compareForMaxHeap=[&](int first,int second) {\n                return isTrimmedLess(nums,first,second,trimLength);\n            };\n\n            priority_queue<int,vector<int>,decltype(compareForMaxHeap)> maxHeap(compareForMaxHeap);\n\n            for(int index=0;index<size;index++) {\n                maxHeap.push(index);\n\n                if((int)maxHeap.size()>kth)\n                    maxHeap.pop();\n            }\n\n            answer.push_back(maxHeap.top());\n        }\n\n        return answer;\n    }\n};"},"approach_5":{"cpp":"class Solution {\n    bool isTrimmedLess(const vector<string>& nums,int first,int second,int trimLength) {\n        int digitCount=nums[0].size();\n\n        for(int pos=digitCount-trimLength;pos<digitCount;pos++) {\n            if(nums[first][pos]!=nums[second][pos])\n                return nums[first][pos]<nums[second][pos];\n        }\n\n        return first<second;\n    }\n\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums,vector<vector<int>>& queries) {\n        int size=nums.size();\n        vector<int> answer;\n\n        for(auto& query:queries) {\n            int kth=query[0];\n            int trimLength=query[1];\n\n            auto compareForMinHeap=[&](int first,int second) {\n                return isTrimmedLess(nums,second,first,trimLength);\n            };\n\n            priority_queue<int,vector<int>,decltype(compareForMinHeap)> minHeap(compareForMinHeap);\n\n            for(int index=0;index<size;index++)\n                minHeap.push(index);\n\n            while(kth>1) {\n                minHeap.pop();\n                kth--;\n            }\n\n            answer.push_back(minHeap.top());\n        }\n\n        return answer;\n    }\n};"},"approach_6":{"cpp":"class Solution {\n    unsigned int seed=2463534242u;\n\n    unsigned int nextRandom() {\n        seed^=seed<<13;\n        seed^=seed>>17;\n        seed^=seed<<5;\n\n        return seed;\n    }\n\n    bool isTrimmedLess(const vector<string>& nums,int first,int second,int trimLength) {\n        int digitCount=nums[0].size();\n\n        for(int pos=digitCount-trimLength;pos<digitCount;pos++) {\n            if(nums[first][pos]!=nums[second][pos])\n                return nums[first][pos]<nums[second][pos];\n        }\n\n        return first<second;\n    }\n\n    int partition(vector<int>& order,int left,int right,const vector<string>& nums,int trimLength) {\n        int pivotIndex=left+nextRandom()%(right-left+1);\n        int pivotValue=order[pivotIndex];\n\n        swap(order[pivotIndex],order[right]);\n\n        int storeIndex=left;\n\n        for(int index=left;index<right;index++) {\n            if(isTrimmedLess(nums,order[index],pivotValue,trimLength)) {\n                swap(order[index],order[storeIndex]);\n                storeIndex++;\n            }\n        }\n\n        swap(order[storeIndex],order[right]);\n\n        return storeIndex;\n    }\n\n    int quickSelect(vector<int>& order,int target,const vector<string>& nums,int trimLength) {\n        int left=0;\n        int right=order.size()-1;\n\n        while(left<=right) {\n            int pivotIndex=partition(order,left,right,nums,trimLength);\n\n            if(pivotIndex==target)\n                return order[pivotIndex];\n\n            if(pivotIndex<target)\n                left=pivotIndex+1;\n            else\n                right=pivotIndex-1;\n        }\n\n        return -1;\n    }\n\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums,vector<vector<int>>& queries) {\n        int size=nums.size();\n        vector<int> answer;\n\n        for(auto& query:queries) {\n            vector<int> order(size);\n\n            iota(order.begin(),order.end(),0);\n            answer.push_back(quickSelect(order,query[0]-1,nums,query[1]));\n        }\n\n        return answer;\n    }\n};"},"approach_7":{"cpp":"class Solution {\n    void sortByDigit(vector<int>& order,vector<int>& buffer,const vector<string>& nums,int digitPos) {\n        int size=order.size();\n        int counts[10]={};\n\n        for(int index:order)\n            counts[nums[index][digitPos]-'0']++;\n\n        for(int i=1;i<10;i++)\n            counts[i]+=counts[i-1];\n\n        for(int i=size-1;i>=0;i--) {\n            int digit=nums[order[i]][digitPos]-'0';\n            buffer[--counts[digit]]=order[i];\n        }\n\n        order.swap(buffer);\n    }\n\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums,vector<vector<int>>& queries) {\n        int size=nums.size();\n        int digitCount=nums[0].size();\n        vector<int> answer;\n\n        for(auto& query:queries) {\n            int kth=query[0];\n            int trimLength=query[1];\n            vector<int> order(size);\n            vector<int> buffer(size);\n\n            iota(order.begin(),order.end(),0);\n\n            for(int digitPos=digitCount-1;digitPos>=digitCount-trimLength;digitPos--)\n                sortByDigit(order,buffer,nums,digitPos);\n\n            answer.push_back(order[kth-1]);\n        }\n\n        return answer;\n    }\n};"},"approach_8":{"cpp":"class Solution {\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums,vector<vector<int>>& queries) {\n        int size=nums.size();\n        int digitCount=nums[0].size();\n        int queryCount=queries.size();\n        int maxTrim=0;\n\n        vector<vector<int>> queryIdsByTrim(digitCount+1);\n\n        for(int queryId=0;queryId<queryCount;queryId++) {\n            int trimLength=queries[queryId][1];\n            queryIdsByTrim[trimLength].push_back(queryId);\n            maxTrim=max(maxTrim,trimLength);\n        }\n\n        vector<int> order(size);\n        vector<int> buffer(size);\n        vector<int> answer(queryCount);\n\n        iota(order.begin(),order.end(),0);\n\n        for(int trimLength=1;trimLength<=maxTrim;trimLength++) {\n            int digitPos=digitCount-trimLength;\n            int counts[10]={};\n\n            for(int index:order)\n                counts[nums[index][digitPos]-'0']++;\n\n            for(int i=1;i<10;i++)\n                counts[i]+=counts[i-1];\n\n            for(int i=size-1;i>=0;i--) {\n                int digit=nums[order[i]][digitPos]-'0';\n                buffer[--counts[digit]]=order[i];\n            }\n\n            order.swap(buffer);\n\n            for(int queryId:queryIdsByTrim[trimLength])\n                answer[queryId]=order[queries[queryId][0]-1];\n        }\n\n        return answer;\n    }\n};"},"approach_9":{"cpp":"class Solution {\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums,vector<vector<int>>& queries) {\n        int size=nums.size();\n        int digitCount=nums[0].size();\n\n        vector<vector<int>> orderByTrim(digitCount+1,vector<int>(size));\n        vector<int> order(size);\n        vector<int> buffer(size);\n\n        iota(order.begin(),order.end(),0);\n\n        for(int trimLength=1;trimLength<=digitCount;trimLength++) {\n            int counts[10]={};\n            int digitPos=digitCount-trimLength;\n\n            for(int index:order)\n                counts[nums[index][digitPos]-'0']++;\n\n            for(int i=1;i<10;i++)\n                counts[i]+=counts[i-1];\n\n            for(int i=size-1;i>=0;i--) {\n                int digit=nums[order[i]][digitPos]-'0';\n                buffer[--counts[digit]]=order[i];\n            }\n\n            order.swap(buffer);\n            orderByTrim[trimLength]=order;\n        }\n\n        vector<int> answer;\n\n        for(auto& query:queries)\n            answer.push_back(orderByTrim[query[1]][query[0]-1]);\n\n        return answer;\n    }\n};"}}}]
